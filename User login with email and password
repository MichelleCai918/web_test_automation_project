import sys

def generate_test_cases(feature):
    test_cases = [
        f"Test Case 1: Verify successful {feature}.",
        f"Test Case 2: Verify error message when incorrect credentials are entered for {feature}.",
        f"Test Case 3: Verify validation when required fields for {feature} are left empty.",
        f"Test Case 4: Verify system response when invalid input format is used in {feature}.",
        f"Test Case 5: Verify system behavior when multiple failed attempts occur during {feature}."
    ]
    
    return test_cases

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python generate_test_cases.py 'feature description'")
    else:
        feature = sys.argv[1]
        cases = generate_test_cases(feature)
        
        print("\nGenerated Test Cases:\n")
        for case in cases:
            print(case)
